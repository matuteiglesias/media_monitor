{
  "name": "news-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "test:refresh-data": "node --test scripts/refresh_public_data.test.mjs",
    "prebuild": "python3 ../../scripts/validate_site_snapshot.py --site-id \"${SITE_ID:-argentina-general}\" --digest-at \"${DIGEST_AT:-$(date -u +%Y%m%dT%H)}\" --sites-dir ../../sites --input public/data/site_snapshot.json"
  },
  "dependencies": {
    "next": "14.2.25",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.25",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "@tailwindcss/typography": "^0.5.15",
    "typescript": "^5.6.3"
  }
}
