{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://media-monitor/contracts/scrape_request.v1.json",
  "title": "scrape_request.v1",
  "description": "Stable scrape request from current articles_to_scrape planning seam.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_name": { "const": "scrape_request.v1" },
    "schema_status": { "const": "stable" },
    "digest_id_hour": { "type": "string", "pattern": "^[0-9]{8}T[0-9]{2}$" },
    "index_id": { "type": "string", "pattern": "^[A-Z2-7]{10}$" },
    "topic": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "original_link": { "type": "string", "format": "uri" },
    "published": { "type": "string", "format": "date-time" },
    "digest_file": { "type": "string", "minLength": 1 },
    "article_id": { "type": "string", "minLength": 1 },
    "join_key": { "type": "string" }
  },
  "required": [
    "schema_name",
    "schema_status",
    "digest_id_hour",
    "index_id",
    "topic",
    "source",
    "title",
    "original_link",
    "published",
    "digest_file",
    "article_id",
    "join_key"
  ]
}
