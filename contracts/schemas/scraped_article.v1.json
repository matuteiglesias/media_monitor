{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://media-monitor/contracts/scraped_article.v1.json",
  "title": "scraped_article.v1",
  "description": "Schema-valid article text enrichment artifact emitted by news_enrich.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_name": { "const": "scraped_article.v1" },
    "schema_status": { "const": "experimental" },
    "index_id": { "type": "string", "minLength": 1 },
    "source_url": { "type": "string", "format": "uri" },
    "final_url": { "type": "string", "format": "uri" },
    "fetched_at": { "type": "string", "format": "date-time" },
    "fetch_status": { "type": "string", "enum": ["success", "failed", "blocked", "empty", "timeout"] },
    "title": { "type": "string" },
    "source": { "type": "string" },
    "topic": { "type": "string" },
    "text": { "type": "string" },
    "text_hash": { "type": "string" },
    "byte_size": { "type": "integer", "minimum": 0 },
    "char_count": { "type": "integer", "minimum": 0 },
    "language": { "type": ["string", "null"] },
    "error_code": { "type": "string" },
    "error_message": { "type": "string" },
    "extractor": { "type": "string" },
    "meta": { "type": "object" }
  },
  "required": [
    "schema_name",
    "schema_status",
    "index_id",
    "source_url",
    "final_url",
    "fetched_at",
    "fetch_status",
    "title",
    "source",
    "topic",
    "text",
    "text_hash",
    "byte_size",
    "char_count",
    "language",
    "error_code",
    "error_message",
    "extractor",
    "meta"
  ]
}
