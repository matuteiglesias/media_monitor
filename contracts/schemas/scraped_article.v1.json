{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://media-monitor/contracts/scraped_article.v1.json",
  "title": "scraped_article.v1",
  "description": "Stable scraped article record aligned with backend.models.ScrapeRecordV1.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_name": { "const": "scraped_article.v1" },
    "schema_status": { "const": "stable" },
    "index_id": { "type": "string", "pattern": "^[A-Z2-7]{10}$" },
    "digest_id_hour": { "type": "string", "pattern": "^[0-9]{8}T[0-9]{2}$" },
    "topic": { "type": "string" },
    "source": { "type": "string" },
    "title": { "type": "string" },
    "published": { "type": "string", "format": "date-time" },
    "original_link": { "type": "string", "format": "uri" },
    "final_url": { "type": "string", "format": "uri" },
    "status": { "type": "integer" },
    "fetch_latency_ms": { "type": "integer", "minimum": 0 },
    "raw_html_len": { "type": "integer", "minimum": 0 },
    "main_text": { "type": "string" },
    "main_text_len": { "type": "integer", "minimum": 0 },
    "lang": { "type": ["string", "null"], "enum": ["es", "en", null] },
    "extraction_engine": { "type": "string", "enum": ["trafilatura", "readability", "playwright"] },
    "quality": { "type": "object" },
    "fetched_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "schema_name",
    "schema_status",
    "index_id",
    "digest_id_hour",
    "topic",
    "source",
    "title",
    "published",
    "original_link",
    "final_url",
    "status",
    "fetch_latency_ms",
    "raw_html_len",
    "main_text",
    "main_text_len",
    "extraction_engine",
    "quality",
    "fetched_at"
  ]
}
