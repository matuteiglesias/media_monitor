{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://media-monitor/contracts/published_article.v1.json",
  "title": "published_article.v1",
  "description": "Public article promoted from a reviewed news_article_draft.v1 record.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_name": { "const": "published_article.v1" },
    "article_id": { "type": "string", "minLength": 1 },
    "draft_id": { "type": "string", "minLength": 1 },
    "digest_at": { "type": "string", "pattern": "^[0-9]{8}T[0-9]{2}$" },
    "story_group_id": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "body_md": { "type": "string", "minLength": 1 },
    "topic": { "type": "string", "minLength": 1 },
    "source_links": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "format": "uri" }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "citation_id": { "type": "string", "minLength": 1 },
          "claim_text": { "type": "string", "minLength": 1 },
          "source_ref_id": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["citation_id", "claim_text", "source_ref_id", "url"]
      }
    },
    "status": { "const": "published" },
    "review_status": { "type": "string", "minLength": 1 },
    "published_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "schema_name",
    "article_id",
    "draft_id",
    "digest_at",
    "story_group_id",
    "slug",
    "title",
    "summary",
    "body_md",
    "topic",
    "source_links",
    "citations",
    "status",
    "review_status",
    "published_at",
    "updated_at"
  ]
}
